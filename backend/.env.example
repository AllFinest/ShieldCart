# =============================================================================
# SECURE E-COMMERCE — ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=ecommerce_user
DB_PASSWORD=your_secure_database_password_here
DB_NAME=secure_ecommerce

# --- JWT Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_replace_with_64_byte_hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_jwt_secret_here_replace_with_64_byte_hex
JWT_REFRESH_EXPIRES_IN=7d

# --- CSRF Protection ---
CSRF_SECRET=your_csrf_secret_here_replace_with_32_byte_hex

# --- Stripe Payment (Sandbox) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# --- WebAuthn / FIDO2 ---
WEBAUTHN_RP_NAME=SecureEcommerce
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# --- CORS ---
CORS_ORIGIN=http://localhost:5173

# --- Session ---
SESSION_TIMEOUT_MINUTES=30

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
